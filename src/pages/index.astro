---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getDegree } from '../lib/graph';
import { getTopicColor, getTopicLabel } from '../lib/topics';
import InsightFeed from '../components/InsightFeed';
import '../styles/global.css';

const allInsights = await getCollection('insights');

// Sort by connection count (most connected first)
const insights = allInsights
  .map(insight => ({
    slug: insight.id,
    title: insight.data.title,
    description: insight.data.description,
    topics: insight.data.topics,
    source: insight.data.source,
    degree: getDegree(insight.id),
  }))
  .sort((a, b) => b.degree - a.degree);

// Collect all unique topics
const allTopics = [...new Set(insights.flatMap(i => i.topics))].sort();
---

<Layout title="Knowledge Graph — AI Product Insights">
  <div class="mx-auto max-w-6xl px-4 py-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-text-primary tracking-tight">
        {insights.length} insights on building AI products
      </h1>
      <p class="mt-2 text-sm text-text-muted">
        Source-verified knowledge from practitioners. Browse by topic, search, or <a href={`${import.meta.env.BASE_URL}graph`} class="text-[#818cf8] hover:text-[#a5b4fc] transition-colors">explore the graph</a>.
      </p>
    </div>

    <InsightFeed
      client:load
      insights={insights}
      topics={allTopics}
      basePath={import.meta.env.BASE_URL}
    />
  </div>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { getDegree } from '../lib/graph';
import { getTopicColor, getTopicLabel } from '../lib/topics';
import InsightFeed from '../components/InsightFeed';
import '../styles/global.css';

const allInsights = await getCollection('insights');

// Sort by connection count (most connected first)
const insights = allInsights
  .map(insight => ({
    slug: insight.id,
    title: insight.data.title,
    description: insight.data.description,
    topics: insight.data.topics,
    source: insight.data.source,
    degree: getDegree(insight.id),
  }))
  .sort((a, b) => b.degree - a.degree);

// Collect all unique topics
const allTopics = [...new Set(insights.flatMap(i => i.topics))].sort();
---

<Layout title="Knowledge Graph — AI Product Insights">
  <div class="mx-auto max-w-6xl px-4 py-10">
    <header class="mb-10 animate-fade-in">
      <div class="flex items-baseline gap-3">
        <h1 class="text-3xl font-bold text-text-primary tracking-tight">
          Knowledge Graph
        </h1>
        <span class="rounded-full bg-bg-secondary px-2.5 py-0.5 text-xs font-medium text-text-dim border border-border">
          {insights.length} insights
        </span>
      </div>
      <p class="mt-3 text-[15px] leading-relaxed text-text-muted max-w-2xl">
        Source-verified knowledge on building AI products — from practitioners, not pundits.
        Browse by topic, search, or <a href={`${import.meta.env.BASE_URL}graph`} class="text-[#818cf8] hover:text-[#a5b4fc] border-b border-dashed border-[#818cf860] hover:border-[#a5b4fc] transition-colors">explore the graph</a>.
      </p>
    </header>

    <InsightFeed
      client:load
      insights={insights}
      topics={allTopics}
      basePath={import.meta.env.BASE_URL}
    />
  </div>
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { getConnections, getDegree } from '../../lib/graph';
import { getTopicColor, getTopicLabel } from '../../lib/topics';
import '../../styles/global.css';

export async function getStaticPaths() {
  const insights = await getCollection('insights');
  return insights.map(insight => ({
    params: { slug: insight.id },
    props: { insight },
  }));
}

const { insight } = Astro.props;
const { Content } = await render(insight);
const { title, description, topics, source, date } = insight.data;
const connections = getConnections(insight.id);
const degree = getDegree(insight.id);
const base = import.meta.env.BASE_URL;
---

<Layout title={`${title} — Knowledge Graph`} description={description}>
  <article class="mx-auto max-w-3xl px-4 py-8" data-pagefind-body>
    <!-- Back link -->
    <a href={base} class="inline-flex items-center gap-1.5 text-sm text-text-dim hover:text-text-muted transition-colors mb-6">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="19" y1="12" x2="5" y2="12" /><polyline points="12 19 5 12 12 5" />
      </svg>
      All insights
    </a>

    <!-- Header -->
    <header class="mb-8">
      <div class="flex flex-wrap gap-1.5 mb-4">
        {topics.map((topic: string) => (
          <a
            href={`${base}topic/${topic}`}
            class="inline-flex items-center rounded-full px-2.5 py-0.5 text-[11px] font-medium transition-opacity hover:opacity-80"
            style={{
              backgroundColor: `${getTopicColor(topic)}20`,
              color: getTopicColor(topic),
              border: `1px solid ${getTopicColor(topic)}30`,
            }}
          >
            {getTopicLabel(topic)}
          </a>
        ))}
      </div>

      <h1 class="text-2xl font-bold leading-tight text-text-primary tracking-tight">
        {title}
      </h1>

      <p class="mt-3 text-[15px] leading-relaxed text-text-muted">
        {description}
      </p>

      <div class="mt-4 flex items-center gap-4 text-xs text-text-dim">
        <span>{source}</span>
        {date && <time datetime={date.toISOString().split('T')[0]}>{date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>}
        {degree > 0 && <span>{degree} connections</span>}
      </div>
    </header>

    <!-- Prose content -->
    <div class="prose-insight text-[15px] leading-relaxed text-text-secondary">
      <Content />
    </div>

    <!-- Connections -->
    {(connections.outgoing.length > 0 || connections.incoming.length > 0) && (
      <div class="mt-10 border-t border-border pt-8">
        <h2 class="text-xs font-medium uppercase tracking-widest text-text-dim mb-4">
          Connected Insights
        </h2>

        {connections.outgoing.length > 0 && (
          <div class="mb-6">
            <h3 class="text-[11px] uppercase tracking-wider text-text-dim mb-2">
              References ({connections.outgoing.length})
            </h3>
            <div class="space-y-1">
              {connections.outgoing.map(conn => (
                <a
                  href={`${base}insight/${conn.slug}`}
                  class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-white/5 transition-colors"
                >
                  <span class="text-text-dim">&rarr;</span>
                  {conn.title}
                </a>
              ))}
            </div>
          </div>
        )}

        {connections.incoming.length > 0 && (
          <div>
            <h3 class="text-[11px] uppercase tracking-wider text-text-dim mb-2">
              Referenced by ({connections.incoming.length})
            </h3>
            <div class="space-y-1">
              {connections.incoming.map(conn => (
                <a
                  href={`${base}insight/${conn.slug}`}
                  class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-text-muted hover:text-text-primary hover:bg-white/5 transition-colors"
                >
                  <span class="text-text-dim">&larr;</span>
                  {conn.title}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    )}
  </article>
</Layout>
